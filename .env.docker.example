# Cognolith Docker environment
# Copy to `.env.docker` when you want to run Compose with:
# docker compose --env-file .env.docker --profile ai up --build -d

ENVIRONMENT=local
DEBUG=False

# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_LOCAL_PASSWORD
POSTGRES_DB=knowledge_assistant
POSTGRES_PORT=5432

# HTTP ports
FRONTEND_PORT=8080
BACKEND_PORT=3000
FRONTEND_HOST=http://localhost:8080
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_STREAM_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8080

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# Mailpit is the default Docker email provider.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=False
SMTP_SSL=False
EMAILS_FROM_EMAIL=no-reply@cognolith.local
EMAILS_FROM_NAME=Cognolith
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Optional Gmail SMTP example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail-address@gmail.com
# SMTP_PASSWORD=your-16-character-google-app-password
# SMTP_TLS=True
# SMTP_SSL=False
# EMAILS_FROM_EMAIL=your-gmail-address@gmail.com

# Optional local AI profile
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
