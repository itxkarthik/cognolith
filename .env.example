# Cognolith root environment
# Copy to `.env` when running Docker Compose locally.
# Never commit `.env` after adding real passwords or SMTP credentials.

# App
PROJECT_NAME=Cognolith
PROJECT_DESCRIPTION=A connected workspace for knowledge, memory, and retrieval
ENVIRONMENT=local
DEBUG=False

# Docker ports
FRONTEND_PORT=8080
BACKEND_PORT=3000
POSTGRES_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
OLLAMA_PORT=11434

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_LOCAL_PASSWORD
POSTGRES_DB=knowledge_assistant

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# CORS and public URLs
FRONTEND_HOST=http://localhost:8080
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_STREAM_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:8080

# Email verification: local Docker uses Mailpit.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=False
SMTP_SSL=False
EMAILS_FROM_EMAIL=no-reply@cognolith.local
EMAILS_FROM_NAME=Cognolith

# Local AI
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
